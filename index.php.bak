header('Content-Type: text/html; charset=utf-8');

// Get action parameter for different sections
$action = $_GET['action'] ?? 'dashboard';
$section = $_GET['section'] ?? 'overview';

// System information functions
function getSystemInfo() {
    return [
        'php_version' => PHP_VERSION,
        'zend_version' => zend_version(),
        'memory_limit' => ini_get('memory_limit'),
        'max_execution_time' => ini_get('max_execution_time'),
        'upload_max_filesize' => ini_get('upload_max_filesize'),
        'post_max_size' => ini_get('post_max_size'),
        'current_memory' => memory_get_usage(true),
        'peak_memory' => memory_get_peak_usage(true),
        'loaded_extensions' => count(get_loaded_extensions()),
        'server_time' => date('Y-m-d H:i:s T'),
        'timezone' => date_default_timezone_get(),
        'server_name' => $_SERVER['SERVER_NAME'] ?? 'localhost',
        'document_root' => $_SERVER['DOCUMENT_ROOT'] ?? '/var/www/html',
        'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? 'Unknown',
        'remote_addr' => $_SERVER['REMOTE_ADDR'] ?? 'Unknown',
        'composer_version' => getComposerVersion()
    ];
}

function getComposerVersion() {
    $output = [];
    $return_var = 0;
    exec('composer --version 2>/dev/null', $output, $return_var);
    
    if ($return_var === 0 && !empty($output)) {
        // Extract version from output like "Composer version 2.9.3 2025-12-30 13:40:17"
        if (preg_match('/Composer version (\d+\.\d+\.\d+)/', $output[0], $matches)) {
            return $matches[1];
        }
        return trim($output[0]);
    }
    
    return 'Not installed';
}

function formatBytes($bytes, $precision = 2) {
    $units = array('B', 'KB', 'MB', 'GB', 'TB');
    for ($i = 0; $bytes > 1024; $i++) {
        $bytes /= 1024;
    }
    return round($bytes, $precision) . ' ' . $units[$i];
}

// Extension testing functions
function testExtensions() {
    $required_extensions = [
        'bcmath', 'bz2', 'calendar', 'Core', 'ctype', 'curl', 'date', 'dom',
        'exif', 'fileinfo', 'filter', 'ftp', 'gd', 'gettext', 'hash', 'iconv',
        'intl', 'json', 'libxml', 'mbstring', 'mysqli', 'mysqlnd', 'openssl',
        'pcntl', 'pcre', 'PDO', 'pdo_mysql', 'pdo_pgsql', 'pdo_sqlite', 'pgsql',
        'Phar', 'random', 'readline', 'Reflection', 'session', 'SimpleXML',
        'sockets', 'sodium', 'SPL', 'sqlite3', 'standard', 'tokenizer', 'xml',
        'xmlreader', 'xmlwriter', 'xsl', 'Zend OPcache', 'zip', 'zlib'
    ];
    
    $loaded_extensions = get_loaded_extensions();
    $results = [];
    
    foreach ($required_extensions as $ext) {
        $results[$ext] = in_array($ext, $loaded_extensions);
    }
    
    return $results;
}

// Performance benchmarking functions
function runPerformanceBenchmarks() {
    $results = [];
    
    // CPU benchmark
    $start = microtime(true);
    for ($i = 0; $i < 50000; $i++) {
        sqrt($i) * sin($i);
    }
    $results['cpu'] = round((microtime(true) - $start) * 1000, 2);
    
    // Memory benchmark
    $start = microtime(true);
    $memory_start = memory_get_usage();
    $array = [];
    for ($i = 0; $i < 5000; $i++) {
        $array[] = str_repeat('x', 50);
    }
    $results['memory_time'] = round((microtime(true) - $start) * 1000, 2);
    $results['memory_used'] = formatBytes(memory_get_usage() - $memory_start);
    unset($array);
    
    // String operations
    $start = microtime(true);
    $string = '';
    for ($i = 0; $i < 500; $i++) {
        $string .= md5($i);
    }
    $results['string'] = round((microtime(true) - $start) * 1000, 2);
    
    return $results;
}

// Database testing functions
function testDatabaseConnectivity() {
    $results = [];
    
    // Test MySQL
    if (extension_loaded('mysqli')) {
        $results['mysql'] = [
            'available' => true,
            'version' => mysqli_get_client_info(),
            'status' => 'Extension loaded'
        ];
    } else {
        $results['mysql'] = ['available' => false, 'status' => 'Extension not loaded'];
    }
    
    // Test PostgreSQL
    if (extension_loaded('pgsql')) {
        $results['postgresql'] = [
            'available' => true,
            'version' => 'Client library available',
            'status' => 'Extension loaded'
        ];
    } else {
        $results['postgresql'] = ['available' => false, 'status' => 'Extension not loaded'];
    }
    
    // Test SQLite
    if (extension_loaded('sqlite3')) {
        try {
            $db = new SQLite3(':memory:');
            $db->exec('CREATE TABLE test (id INTEGER PRIMARY KEY, name TEXT)');
            $db->exec("INSERT INTO test (name) VALUES ('Test Record')");
            $stmt = $db->query('SELECT COUNT(*) as count FROM test');
            $row = $stmt->fetchArray();
            $db->close();
            
            $results['sqlite'] = [
                'available' => true,
                'version' => SQLite3::version()['versionString'],
                'status' => 'Functional test passed',
                'test_result' => 'Created and queried ' . $row['count'] . ' record(s)'
            ];
        } catch (Exception $e) {
            $results['sqlite'] = [
                'available' => true,
                'version' => SQLite3::version()['versionString'],
                'status' => 'Extension loaded but test failed: ' . $e->getMessage()
            ];
        }
    } else {
        $results['sqlite'] = ['available' => false, 'status' => 'Extension not loaded'];
    }
    
    // Test PDO
    if (extension_loaded('PDO')) {
        $drivers = PDO::getAvailableDrivers();
        $results['pdo'] = [
            'available' => true,
            'version' => 'PDO available',
            'status' => 'Extension loaded',
            'drivers' => implode(', ', $drivers),
            'driver_count' => count($drivers)
        ];
    } else {
        $results['pdo'] = ['available' => false, 'status' => 'Extension not loaded'];
    }
    
    return $results;
}

// OPcache statistics
function getOPcacheStats() {
    if (!extension_loaded('Zend OPcache')) {
        return ['available' => false];
    }
    
    $status = opcache_get_status();
    if (!$status) {
        return ['available' => true, 'enabled' => false];
    }
    
    return [
        'available' => true,
        'enabled' => true,
        'memory_usage' => $status['memory_usage'],
        'opcache_statistics' => $status['opcache_statistics']
    ];
}

// Security configuration check
function checkSecurityConfig() {
    return [
        'expose_php' => [
            'value' => ini_get('expose_php'),
            'secure' => ini_get('expose_php') == '0',
            'description' => 'PHP version exposure in headers'
        ],
        'display_errors' => [
            'value' => ini_get('display_errors'),
            'secure' => ini_get('display_errors') == '0',
            'description' => 'Error display to users'
        ],
        'log_errors' => [
            'value' => ini_get('log_errors'),
            'secure' => ini_get('log_errors') == '1',
            'description' => 'Error logging enabled'
        ],
        'allow_url_fopen' => [
            'value' => ini_get('allow_url_fopen'),
            'secure' => ini_get('allow_url_fopen') == '0',
            'description' => 'Remote file access'
        ]
    ];
}

// PHP 8.2 features demonstration
readonly class Config {
    public function __construct(
        public string $name,
        public string $version,
        public string $environment
    ) {}
}

$config = new Config("Expressa PHP 8.2 All-in-One Dashboard", "2.0.0", "Development");
$system = getSystemInfo();

// Handle API requests
if ($action === 'api') {
    header('Content-Type: application/json');
    $response = [
        'status' => 'success',
        'message' => 'PHP 8.2 FPM All-in-One Dashboard API',
        'application' => [
            'name' => $config->name,
            'version' => $config->version,
            'environment' => $config->environment
        ],
        'system_info' => $system,
        'timestamp' => time()
    ];
    
    switch ($section) {
        case 'extensions':
            $response['extensions'] = testExtensions();
            break;
        case 'performance':
            $response['performance'] = runPerformanceBenchmarks();
            break;
        case 'database':
            $response['database'] = testDatabaseConnectivity();
            break;
        case 'opcache':
            $response['opcache'] = getOPcacheStats();
            break;
        case 'security':
            $response['security'] = checkSecurityConfig();
            break;
        default:
            $response['available_sections'] = ['extensions', 'performance', 'database', 'opcache', 'security'];
    }
    
    echo json_encode($response, JSON_PRETTY_PRINT);
    exit;
}

// Get data for dashboard
$extensions = testExtensions();
$performance = runPerformanceBenchmarks();
$database = testDatabaseConnectivity();
$opcache = getOPcacheStats();
$security = checkSecurityConfig();

$extension_success_rate = round((count(array_filter($extensions)) / count($extensions)) * 100, 1);
$db_success_rate = round((count(array_filter($database, function($db) { return $db['available']; })) / count($database)) * 100, 1);
$security_score = round((count(array_filter($security, function($sec) { return $sec['secure']; })) / count($security)) * 100, 1);
?>
