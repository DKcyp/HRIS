                            <span class="metric-value"><?= formatBytes($opcache['memory_usage']['wasted_memory']) ?></span>
                        </div>
                    </div>
                    
                    <div class="card">
                        <h4>📊 Statistics</h4>
                        <div class="metric">
                            <span class="metric-label">Hits:</span>
                            <span class="metric-value"><?= number_format($opcache['opcache_statistics']['hits']) ?></span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Misses:</span>
                            <span class="metric-value"><?= number_format($opcache['opcache_statistics']['misses']) ?></span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Hit Rate:</span>
                            <span class="metric-value"><?= round($opcache['opcache_statistics']['opcache_hit_rate'], 2) ?>%</span>
                        </div>
                    </div>
                </div>
            <?php endif; ?>
        </div>
        
        <!-- Security Tab -->
        <div id="security" class="content" style="display:none;">
            <h2>🔒 Security Configuration</h2>
            <p>Security Score: <strong><?= $security_score ?>%</strong> (<?= count(array_filter($security, function($sec) { return $sec['secure']; })) ?>/<?= count($security) ?> settings secure)</p>
            
            <div class="grid">
                <?php foreach ($security as $setting => $info): ?>
                <div class="card">
                    <h4><?= $info['secure'] ? '✅' : '⚠️' ?> <?= $setting ?></h4>
                    <div class="metric">
                        <span class="metric-label">Value:</span>
                        <span class="metric-value"><?= $info['value'] ?></span>
                    </div>
                    <div class="metric">
                        <span class="metric-label">Status:</span>
                        <span class="metric-value"><?= $info['secure'] ? 'Secure' : 'Needs attention' ?></span>
                    </div>
                    <p style="margin-top: 10px; font-size: 0.9em; color: #64748b;"><?= $info['description'] ?></p>
                </div>
                <?php endforeach; ?>
            </div>
        </div>
        
        <!-- API Tab -->
        <div id="api" class="content" style="display:none;">
            <h2>🔌 API Endpoints</h2>
            <p>JSON API endpoints for programmatic access to all dashboard data.</p>
            
            <div class="api-links">
                <strong>Available API Endpoints:</strong><br><br>
