                <a href="?action=api&section=performance">⚡ Performance Data</a>
                <a href="?action=api&section=database">🗄️ Database Data</a>
                <a href="?action=api&section=opcache">🚀 OPcache Data</a>
                <a href="?action=api&section=security">🔒 Security Data</a>
            </div>
            
            <h3>Example API Response:</h3>
